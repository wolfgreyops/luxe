{% comment %}
  Six Thirteen — Product Configurator Page Template
  ================================================

  HOW TO INSTALL:
  1. In Shopify Admin → Online Store → Themes → Edit Code
  2. Under "Templates", click "Add a new template"
  3. Choose "page" and name it "configurator"
  4. Paste this entire file as the template content
  5. Create a new Page (Online Store → Pages) and select "configurator" as the template
  6. Update CONFIGURATOR_URL below to your actual Vercel deployment URL

  REQUIREMENTS:
  - A Shopify product for "Custom Tee" with variants for each size (S, M, L, XL, 2XL)
  - The configurator-shopify.html deployed on Vercel
  - Update the variant IDs in the VARIANT_MAP below
{% endcomment %}

{% comment %} Disable the default page header/footer for full-screen configurator {% endcomment %}
{% layout none %}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Design Your Own Tee — Six Thirteen</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body {
      height: 100%;
      overflow: hidden;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    .configurator-iframe {
      width: 100vw;
      height: 100vh;
      border: none;
      display: block;
    }

    /* Cart notification toast */
    .cart-toast {
      position: fixed;
      top: 20px;
      right: 20px;
      background: #1a1a1a;
      color: #fff;
      padding: 16px 24px;
      border-radius: 8px;
      font-size: 14px;
      z-index: 9999;
      transform: translateX(120%);
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 20px rgba(0,0,0,0.3);
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .cart-toast.visible {
      transform: translateX(0);
    }
    .cart-toast a {
      color: #9a65fa;
      text-decoration: none;
      font-weight: 600;
    }
    .cart-toast a:hover {
      text-decoration: underline;
    }
    .cart-toast .checkmark {
      width: 20px;
      height: 20px;
      background: #22c55e;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .cart-toast .checkmark svg {
      width: 12px;
      height: 12px;
    }
  </style>
</head>
<body>

{% comment %}
  ============================================
  CONFIGURATION — UPDATE THESE VALUES
  ============================================
{% endcomment %}

{% comment %}
  Replace this URL with your actual Vercel deployment URL
  e.g., https://your-project.vercel.app/configurator-shopify.html
{% endcomment %}
{% assign configurator_url = "https://luxe-pi-blush.vercel.app/configurator-shopify.html" %}

<iframe
  id="configuratorFrame"
  class="configurator-iframe"
  src="{{ configurator_url }}"
  allow="clipboard-write"
  loading="eager"
></iframe>

<!-- Cart Added Toast -->
<div class="cart-toast" id="cartToast">
  <span class="checkmark">
    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round">
      <polyline points="20 6 9 17 4 12"/>
    </svg>
  </span>
  <span>Added to cart! <a href="/cart">View Cart →</a></span>
</div>

<script>
  // ============================================
  // VARIANT MAP — Update with your actual Shopify variant IDs
  // ============================================
  // Find these in Shopify Admin → Products → Your Custom Tee → Variants
  // Each variant should correspond to a size
  const VARIANT_MAP = {
    'S':   47583849382042,
    'M':   47583849414810,
    'L':   47583849447578,
    'XL':  47583849480346,
    '2XL': 47583849513114,
  };

  // If you prefer a single variant, set this (the size will be passed as a line item property)
  const SINGLE_VARIANT_ID = null; // e.g., 44123456789000

  // ============================================
  // Listen for messages from the configurator
  // ============================================
  window.addEventListener('message', async function(event) {
    const frame = document.getElementById('configuratorFrame');
    const configuratorOrigin = new URL(frame.src).origin;

    // Accept messages from configurator origin
    if (event.origin !== configuratorOrigin) {
      console.log('[Shopify] Ignored message from:', event.origin, '(expected:', configuratorOrigin, ')');
      return;
    }
    if (!event.data || event.data.action !== 'addToCart') return;

    console.log('[Shopify] Received addToCart:', event.data);

    const { color, sizes, totalQty, artFiles, mockupUrl } = event.data;
    const errors = [];

    console.log('[Shopify] Art files:', artFiles);
    console.log('[Shopify] Mockup URL:', mockupUrl);

    try {
      // Add each size as a separate line item
      for (const [size, quantity] of Object.entries(sizes)) {
        const variantId = VARIANT_MAP[size] || SINGLE_VARIANT_ID;

        if (!variantId) {
          errors.push(`No variant ID for size ${size}`);
          console.error(`[Shopify] No variant ID configured for size: ${size}`);
          continue;
        }

        const properties = {
          'Shirt Color': color,
        };

        // If using a single variant, include size as property
        if (!VARIANT_MAP[size] && SINGLE_VARIANT_ID) {
          properties['Size'] = size;
        }

        // Attach art file URLs (visible in Shopify order details)
        if (artFiles && artFiles.length > 0) {
          artFiles.forEach((art, i) => {
            properties[`_Art File ${i + 1}`] = art.url;
          });
        }

        // Attach mockup preview URL (no underscore prefix so it's visible to customer)
        if (mockupUrl) {
          properties['Design Preview'] = mockupUrl;
        }

        console.log(`[Shopify] Adding to cart: variant=${variantId}, qty=${quantity}, size=${size}, properties:`, properties);

        const res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({
            id: variantId,
            quantity: quantity,
            properties: properties,
          }),
        });

        if (!res.ok) {
          const errBody = await res.text();
          console.error(`[Shopify] Cart add failed (${res.status}):`, errBody);
          errors.push(`Size ${size}: ${errBody}`);
        } else {
          console.log(`[Shopify] Successfully added size ${size}`);
        }
      }

      if (errors.length > 0 && errors.length === Object.keys(sizes).length) {
        // All items failed
        throw new Error(errors.join('; '));
      }

      // Notify the configurator that items were added
      frame.contentWindow.postMessage(
        { action: 'cartAdded', success: true },
        '*'
      );

      // Show toast notification
      showCartToast();

    } catch (err) {
      console.error('[Shopify] Failed to add to cart:', err);

      frame.contentWindow.postMessage(
        { action: 'cartAdded', success: false, error: err.message },
        '*'
      );
    }
  });

  // ============================================
  // Toast notification
  // ============================================
  function showCartToast() {
    const toast = document.getElementById('cartToast');
    toast.classList.add('visible');
    setTimeout(() => {
      toast.classList.remove('visible');
    }, 5000);
  }
</script>

</body>
</html>
