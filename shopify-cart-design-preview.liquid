{% comment %}
  ============================================================
  Six Thirteen — Cart Design Preview
  ============================================================
  Replaces the default product thumbnail with the mockup preview
  for Custom DTF line items, and hides the raw "Design Preview" URL.

  INSTALLATION:
  1. Go to Online Store → Themes → Edit Code
  2. Under "Snippets", click "Add a new snippet"
  3. Name it: cart-design-preview
  4. Paste this entire file and Save
  5. Open your theme's layout/theme.liquid
  6. Add this BEFORE </body>:
         {% render 'cart-design-preview' %}
  ============================================================
{% endcomment %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  function enhanceCart() {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        console.log('[Six13] Cart data:', cart.items.length, 'items');

        cart.items.forEach(function(item, idx) {
          if (!item.properties) return;
          var mockupUrl = item.properties['_Design Preview'] || item.properties['Design Preview'] || null;
          if (!mockupUrl || mockupUrl.indexOf('http') === -1) return;

          console.log('[Six13] Item', idx, 'has mockup:', mockupUrl);

          // Get the product image filename from the cart item
          // item.image is like "//cdn.shopify.com/.../5001_STAPLE_TEE_BLACK.jpg?v=..."
          var productImageUrl = item.image || item.featured_image && item.featured_image.url || '';
          // Extract just the filename part for matching (e.g. "5001_STAPLE_TEE_BLACK")
          var imageName = productImageUrl.split('/').pop().split('?')[0].split('.')[0];

          console.log('[Six13] Looking for product image containing:', imageName);

          // Find the matching img on the page by matching the product image filename
          var replaced = false;
          if (imageName) {
            document.querySelectorAll('img').forEach(function(img) {
              if (replaced) return;
              var src = img.src || '';
              if (src.indexOf(imageName) !== -1) {
                // Extra safety: skip if this image is in the header/nav
                var inHeader = img.closest('header') || img.closest('nav') || img.closest('[class*="header"]') || img.closest('.site-header') || img.closest('#header');
                if (inHeader) {
                  console.log('[Six13] Skipping header image:', src.substring(0, 60));
                  return;
                }
                img.src = mockupUrl;
                img.srcset = '';
                img.alt = 'Your Custom Design';
                img.style.objectFit = 'contain';
                img.style.background = '#f5f5f5';
                replaced = true;
                console.log('[Six13] Swapped product image for item', idx);
              }
            });
          }

          if (!replaced) {
            console.warn('[Six13] Could not find product image for item', idx);
          }
        });

        // No need to hide URLs — _Design Preview is auto-hidden by Shopify
        // (underscore-prefixed properties are hidden from customer-facing pages)
      })
      .catch(function(err) {
        console.error('[Six13] Cart enhance error:', err);
      });
  }

  setTimeout(enhanceCart, 800);

  // Re-run after any AJAX cart update (qty changes, etc.)
  var debounceTimer;
  var observer = new MutationObserver(function() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(enhanceCart, 300);
  });

  // Watch the whole body but only subtree changes — cart drawers/forms live anywhere
  observer.observe(document.body, { childList: true, subtree: true });
});
</script>
