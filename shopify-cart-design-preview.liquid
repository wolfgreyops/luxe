{% comment %}
  ============================================================
  Six Thirteen — Cart Design Preview
  ============================================================
  Shows mockup preview images for Custom DTF line items in the cart.

  INSTALLATION:
  1. Go to Online Store → Themes → Edit Code
  2. Under "Snippets", click "Add a new snippet"
  3. Name it: cart-design-preview
  4. Paste this entire file and Save
  5. Open your theme's layout/theme.liquid
  6. Add this BEFORE </body>:
         {% render 'cart-design-preview' %}
  ============================================================
{% endcomment %}

<style>
  .six13-preview-wrap {
    margin-top: 10px;
    padding: 10px;
    background: #f9f9f9;
    border-radius: 8px;
    border: 1px solid #eee;
  }
  .six13-preview-wrap img {
    max-width: 180px;
    border-radius: 6px;
    border: 1px solid #e0e0e0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    display: block;
    margin-top: 6px;
  }
  .six13-preview-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #7a35f8;
    margin-bottom: 4px;
  }
  .six13-art-link {
    display: inline-block;
    margin-top: 6px;
    font-size: 0.72rem;
    color: #7a35f8;
    text-decoration: none;
    padding: 4px 10px;
    border: 1px solid #7a35f8;
    border-radius: 4px;
    transition: all 0.2s;
  }
  .six13-art-link:hover {
    background: #7a35f8;
    color: #fff;
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  function enhanceCart() {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        console.log('[Six13] Cart data:', cart.items.length, 'items');

        cart.items.forEach(function(item, idx) {
          if (!item.properties) return;

          var mockupUrl = item.properties['Design Preview'] || null;
          var artFiles = [];

          // Collect art file URLs
          Object.keys(item.properties).forEach(function(key) {
            var val = item.properties[key];
            if (key.indexOf('_Art File') === 0 && val && val.indexOf('http') === 0) {
              artFiles.push({ label: key.replace('_', ''), url: val });
            }
          });

          console.log('[Six13] Item', idx, '- mockup:', mockupUrl, '- art files:', artFiles.length);

          if (!mockupUrl && artFiles.length === 0) return;

          // Find the cart line item element in the DOM
          // Try multiple selectors that common Shopify themes use
          var cartItems = document.querySelectorAll(
            'cart-item, .cart-item, .cart__item, [data-cart-item], .cart-item--product, .line-item, .cart__row, .cart-drawer__item, .cart__table-row, table.cart tbody tr, .cart__content .cart__items > *, [data-line-item], .cart-items .cart-item'
          );

          console.log('[Six13] Found', cartItems.length, 'cart DOM items');

          var lineEl = cartItems[idx];
          if (!lineEl) {
            console.warn('[Six13] Could not find DOM element for cart item', idx);
            return;
          }
          if (lineEl.dataset && lineEl.dataset.six13Enhanced) return;
          if (lineEl.dataset) lineEl.dataset.six13Enhanced = 'true';

          var wrap = document.createElement('div');
          wrap.className = 'six13-preview-wrap';

          // Mockup preview
          if (mockupUrl && mockupUrl.indexOf('http') === 0) {
            wrap.innerHTML += '<div class="six13-preview-label">Your Design</div>' +
              '<a href="' + mockupUrl + '" target="_blank">' +
              '<img src="' + mockupUrl + '" alt="Design Preview" loading="lazy">' +
              '</a>';
          }

          // Art file download links
          if (artFiles.length > 0) {
            var linksHtml = artFiles.map(function(f) {
              return '<a class="six13-art-link" href="' + f.url + '" target="_blank" download>⬇ ' + f.label + '</a>';
            }).join(' ');
            wrap.innerHTML += '<div style="margin-top:8px;">' +
              '<div class="six13-preview-label">Print Files</div>' +
              linksHtml + '</div>';
          }

          // Append to the line item element
          lineEl.appendChild(wrap);
        });
      })
      .catch(function(err) {
        console.error('[Six13] Cart enhance error:', err);
      });
  }

  // Run after a short delay to let the cart page render
  setTimeout(enhanceCart, 800);
});
</script>
