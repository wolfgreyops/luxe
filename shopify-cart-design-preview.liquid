{% comment %}
  ============================================================
  Six Thirteen — Cart Design Preview
  ============================================================
  Replaces the default product thumbnail with the mockup preview
  for Custom DTF line items. Persists through AJAX cart updates.

  INSTALLATION:
  1. Go to Online Store → Themes → Edit Code
  2. Under "Snippets", click "Add a new snippet"
  3. Name it: cart-design-preview
  4. Paste this entire file and Save
  5. Open your theme's layout/theme.liquid
  6. Add this BEFORE </body>:
         {% render 'cart-design-preview' %}
  ============================================================
{% endcomment %}

<script>
document.addEventListener('DOMContentLoaded', function() {

  function enhanceCart() {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        if (!cart.items || cart.items.length === 0) return;

        // Collect mockup data per line item
        var mockups = [];
        cart.items.forEach(function(item) {
          var url = item.properties && (item.properties['_Design Preview'] || item.properties['Design Preview']);
          var imgName = (item.image || '').split('/').pop().split('?')[0].split('.')[0];
          mockups.push({
            url: (url && url.indexOf('http') !== -1) ? url : null,
            imgName: imgName
          });
        });

        if (!mockups.some(function(m) { return m.url; })) return;

        // Find the cart form/container
        var cartForm = document.querySelector('form[action="/cart"]') ||
                       document.querySelector('[data-cart-form]') ||
                       document.querySelector('.cart-form') ||
                       document.querySelector('.cart');
        if (!cartForm) return;

        // Try position-based matching via common cart item selectors
        var selectors = [
          '.cart-item', '[data-cart-item]', '.cart__item',
          'cart-items .line-item', '.js-cart-item', 'tbody tr',
          '.cart__row:not(.cart__row--heading)', '.cart-drawer__item'
        ];
        var itemEls = null;
        for (var s = 0; s < selectors.length; s++) {
          var found = cartForm.querySelectorAll(selectors[s]);
          if (found.length === cart.items.length) {
            itemEls = found;
            break;
          }
        }

        mockups.forEach(function(m, idx) {
          if (!m.url) return;
          var img = null;

          // Method 1: position-based (most reliable)
          if (itemEls && itemEls[idx]) {
            img = itemEls[idx].querySelector('img');
          }

          // Method 2: match by product image filename in src
          if (!img && m.imgName) {
            var allImgs = cartForm.querySelectorAll('img');
            for (var i = 0; i < allImgs.length; i++) {
              var src = allImgs[i].src || allImgs[i].getAttribute('data-src') || '';
              if (src.indexOf(m.imgName) !== -1) {
                var inHeader = allImgs[i].closest('header') || allImgs[i].closest('nav');
                if (!inHeader) { img = allImgs[i]; break; }
              }
            }
          }

          // Method 3: match by data-original-src (images we previously swapped)
          if (!img && m.imgName) {
            var tagged = cartForm.querySelectorAll('img[data-original-src]');
            for (var i = 0; i < tagged.length; i++) {
              if (tagged[i].dataset.originalSrc.indexOf(m.imgName) !== -1) {
                img = tagged[i]; break;
              }
            }
          }

          if (img && img.src !== m.url) {
            if (!img.dataset.originalSrc) img.dataset.originalSrc = img.src;
            img.src = m.url;
            img.srcset = '';
            img.alt = 'Your Custom Design';
            img.style.setProperty('object-fit', 'contain', 'important');
            img.style.setProperty('aspect-ratio', 'auto', 'important');
            img.style.setProperty('height', 'auto', 'important');
            img.style.background = '#f5f5f5';
          }
        });
      })
      .catch(function(err) {
        console.error('[Six13] Cart enhance error:', err);
      });
  }

  // Run on page load
  setTimeout(enhanceCart, 500);

  // Hook into fetch to detect cart AJAX updates
  var origFetch = window.fetch;
  window.fetch = function() {
    var url = typeof arguments[0] === 'string' ? arguments[0] : (arguments[0] && arguments[0].url) || '';
    var result = origFetch.apply(this, arguments);
    if (url.indexOf('/cart') !== -1) {
      result.then(function() { setTimeout(enhanceCart, 600); }).catch(function() {});
    }
    return result;
  };

  // Hook into XMLHttpRequest for themes using XHR
  var origOpen = XMLHttpRequest.prototype.open;
  XMLHttpRequest.prototype.open = function(method, url) {
    if (url && url.indexOf('/cart') !== -1) {
      this.addEventListener('load', function() { setTimeout(enhanceCart, 600); });
    }
    return origOpen.apply(this, arguments);
  };

  // MutationObserver as backup with longer debounce
  var debounceTimer;
  var observer = new MutationObserver(function() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(enhanceCart, 800);
  });
  observer.observe(document.body, { childList: true, subtree: true });
});
</script>
