{% comment %}
  ============================================================
  Six Thirteen — Cart Design Preview
  ============================================================
  Replaces the default product thumbnail with the mockup preview
  for Custom DTF line items, and hides the raw "Design Preview" URL.

  INSTALLATION:
  1. Go to Online Store → Themes → Edit Code
  2. Under "Snippets", click "Add a new snippet"
  3. Name it: cart-design-preview
  4. Paste this entire file and Save
  5. Open your theme's layout/theme.liquid
  6. Add this BEFORE </body>:
         {% render 'cart-design-preview' %}
  ============================================================
{% endcomment %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  function enhanceCart() {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        console.log('[Six13] Cart data:', cart.items.length, 'items');

        // Collect all mockup URLs from cart items that have them
        var mockups = [];
        cart.items.forEach(function(item, idx) {
          if (!item.properties) return;
          var mockupUrl = item.properties['Design Preview'] || null;
          if (mockupUrl && mockupUrl.indexOf('http') === 0) {
            mockups.push({ idx: idx, url: mockupUrl, productImage: item.image });
            console.log('[Six13] Item', idx, 'has mockup:', mockupUrl);
          }
        });

        if (mockups.length === 0) {
          console.log('[Six13] No items with mockup URLs');
          return;
        }

        // Strategy: find all product images on the page and replace them
        // Shopify cart images come from the CDN (cdn.shopify.com or the store domain /cdn/)
        var allImages = document.querySelectorAll('img');
        var productImages = [];

        allImages.forEach(function(img) {
          var src = img.src || '';
          // Match Shopify CDN product images
          if (src.indexOf('/cdn/shop/') !== -1 || src.indexOf('cdn.shopify.com') !== -1) {
            // Check this is likely a cart product image (not a logo, icon, etc.)
            // Cart product images are typically 100-300px
            var w = img.naturalWidth || img.width || img.offsetWidth;
            if (w > 40 || img.classList.contains('media-style') || img.closest('[class*="cart"]') || img.closest('[class*="line"]')) {
              productImages.push(img);
            }
          }
        });

        console.log('[Six13] Found', productImages.length, 'product images in cart');

        // Match product images to mockups by order
        // If there's only 1 mockup and 1 product image, it's a direct match
        // For multiple items, match by index
        mockups.forEach(function(m, i) {
          var img = productImages[m.idx] || productImages[i];
          if (img) {
            img.src = m.url;
            img.srcset = '';
            img.alt = 'Your Custom Design';
            img.style.objectFit = 'contain';
            img.style.background = '#f5f5f5';
            console.log('[Six13] Swapped image for item', m.idx);
          } else {
            console.warn('[Six13] No product image found for item', m.idx);
          }
        });

        // Hide the raw "Design Preview: https://..." text
        var walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, null, false);
        while (walker.nextNode()) {
          var node = walker.currentNode;
          if (node.textContent.indexOf('Design Preview') !== -1) {
            var parent = node.parentElement;
            if (parent && parent.textContent.indexOf('http') !== -1) {
              // This is the "Design Preview: https://..." line — hide it
              parent.style.display = 'none';
              console.log('[Six13] Hid Design Preview text');
            }
          }
        }
      })
      .catch(function(err) {
        console.error('[Six13] Cart enhance error:', err);
      });
  }

  setTimeout(enhanceCart, 800);
});
</script>
