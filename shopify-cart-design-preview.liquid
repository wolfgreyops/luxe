{% comment %}
  ============================================================
  Six Thirteen — Cart Design Preview
  ============================================================
  Replaces the default product thumbnail with the mockup preview
  for Custom DTF line items, and hides the raw "Design Preview" URL.

  INSTALLATION:
  1. Go to Online Store → Themes → Edit Code
  2. Under "Snippets", click "Add a new snippet"
  3. Name it: cart-design-preview
  4. Paste this entire file and Save
  5. Open your theme's layout/theme.liquid
  6. Add this BEFORE </body>:
         {% render 'cart-design-preview' %}
  ============================================================
{% endcomment %}

<style>
  /* Hide the raw "Design Preview" URL text from cart properties list */
  .cart-item__property [data-six13-hide],
  .cart__item .product-option [data-six13-hide],
  .cart-item .cart-item__details [data-six13-hide],
  .six13-hide-prop { display: none !important; }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  function enhanceCart() {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        console.log('[Six13] Cart data:', cart.items.length, 'items');

        cart.items.forEach(function(item, idx) {
          if (!item.properties) return;

          var mockupUrl = item.properties['Design Preview'] || null;
          var artFiles = [];

          Object.keys(item.properties).forEach(function(key) {
            var val = item.properties[key];
            if (key.indexOf('_Art File') === 0 && val && val.indexOf('http') === 0) {
              artFiles.push({ label: key.replace('_', ''), url: val });
            }
          });

          console.log('[Six13] Item', idx, '- mockup:', mockupUrl, '- art files:', artFiles.length);

          if (!mockupUrl && artFiles.length === 0) return;

          // Find cart line items in DOM
          var cartItems = document.querySelectorAll(
            'cart-item, .cart-item, .cart__item, [data-cart-item], .cart-item--product, .line-item, .cart__row, .cart-drawer__item, .cart__table-row, table.cart tbody tr, .cart__content .cart__items > *, [data-line-item], .cart-items .cart-item'
          );

          var lineEl = cartItems[idx];
          if (!lineEl) {
            console.warn('[Six13] Could not find DOM element for cart item', idx);
            return;
          }
          if (lineEl.dataset && lineEl.dataset.six13Enhanced) return;
          if (lineEl.dataset) lineEl.dataset.six13Enhanced = 'true';

          // 1. Replace the product thumbnail with the mockup
          if (mockupUrl && mockupUrl.indexOf('http') === 0) {
            var img = lineEl.querySelector('img');
            if (img) {
              img.src = mockupUrl;
              img.srcset = '';
              img.alt = 'Your Custom Design';
              img.style.objectFit = 'contain';
              img.style.background = '#f5f5f5';
              console.log('[Six13] Replaced product image for item', idx);
            }
          }

          // 2. Hide the raw "Design Preview: https://..." text in properties
          var allProps = lineEl.querySelectorAll('dt, dd, li, span, p, div');
          allProps.forEach(function(el) {
            var text = el.textContent || '';
            if (text.indexOf('Design Preview') !== -1 && text.indexOf('http') !== -1) {
              el.style.display = 'none';
            }
            // Also hide if it's a label + value pair
            if (text.trim() === 'Design Preview' || text.trim() === 'Design Preview:') {
              el.style.display = 'none';
              // Hide the next sibling too (the URL value)
              if (el.nextElementSibling) el.nextElementSibling.style.display = 'none';
            }
          });
        });
      })
      .catch(function(err) {
        console.error('[Six13] Cart enhance error:', err);
      });
  }

  // Run after a short delay to let the cart page render
  setTimeout(enhanceCart, 800);
});
</script>
